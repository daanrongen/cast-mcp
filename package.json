{
  "name": "@daanrongen/cast-mcp",
  "version": "1.1.4",
  "description": "MCP server for Google Cast — discover devices, play media, control volume, launch apps, and manage queues over stdio",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daanrongen/cast-mcp.git"
  },
  "bin": {
    "cast-mcp": "./dist/main.js"
  },
  "main": "./dist/main.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "inspect": "DANGEROUSLY_OMIT_AUTH=true mcp-inspector bun src/main.ts",
    "build": "bun build src/main.ts --outfile dist/main.js --target bun --external castv2 --external castv2-client --external multicast-dns",
    "typecheck": "tsc -p tsconfig.check.json",
    "test": "bun test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major",
    "postversion": "git push --follow-tags"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "castv2": "^0.1.10",
    "castv2-client": "^1.2.0",
    "effect": "^3.21.0",
    "multicast-dns": "^7.2.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/castv2": "^0.1.3",
    "@types/multicast-dns": "^7.2.4",
    "bun-types": "latest",
    "lefthook": "^2.1.5",
    "typescript": "^5.8.3"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "keywords": [
    "mcp",
    "google-cast",
    "chromecast",
    "model-context-protocol",
    "effect"
  ],
  "publishConfig": {
    "access": "public"
  }
}
